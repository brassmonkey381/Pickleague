{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    // The local @stockman/rn-foundation package is linked as a junction (file:../shared).
    // Without this, tsc resolves the junction to its real path and then can't find the
    // package's peer deps (react, react-native, expo-*). Keeping the link path lets those
    // resolve through this app's node_modules (a single, shared copy).
    "preserveSymlinks": true
  }
}
